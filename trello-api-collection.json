    {
      "name": "Get Created Board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Response status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "let jsonData = pm.response.json();",
              "",
              "pm.test('Response JSON has closed as false', function () {",
              "    pm.expect(jsonData.closed).to.eql(false);",
              "});",
              "",
              "pm.test('Response JSON has descData as null', function () {",
              "    pm.expect(jsonData.descData).to.eql(null);",
              "});",
              "",
              "let boardid = pm.environment.get(\"boardID\");",
              "pm.test('Response JSON has the created board id', function () {",
              "    pm.expect(jsonData.id).to.eql(boardid);",
              "});"
