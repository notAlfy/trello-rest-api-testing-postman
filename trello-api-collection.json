  "item": [
    {
      "name": "Create a Board",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let randomNum = Math.floor(Math.random() * 1000);\r",
              "let boardName = \"myboard\" + randomNum;\r",
              "\r",
              "pm.environment.set(\"myboardname\", boardName);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();",
              "pm.environment.set(\"boardID\", jsonData.id);",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains id\", function () {",
              "    pm.expect(jsonData).to.have.property(\"id\");",
              "    pm.expect(jsonData.id).to.exist;",
              "    pm.expect(String(jsonData.id).trim()).to.not.equal(\"\");",
              "});",
              "",
              "let boardName = pm.environment.get(\"myboardname\");",
              "pm.test(\"Response contains correct board name\", function () {",
              "    pm.expect(jsonData).to.have.property(\"name\");",
              "    pm.expect(jsonData.name).to.exist;",
              "    pm.expect(String(jsonData.name).trim()).to.not.equal(\"\");",
              "    pm.expect(jsonData.name).to.eql(boardName);",
              "",
              "});",
              "",
              "pm.test(\"Response contains url\", function () {",
              "    pm.expect(jsonData).to.have.property(\"url\");",
              "    pm.expect(jsonData.url).to.exist;",
              "    pm.expect(String(jsonData.url).trim()).to.not.equal(\"\");",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
